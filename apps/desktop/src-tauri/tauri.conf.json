{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Margin",
  "version": "0.1.0",
  "identifier": "app.margin.desktop",
  "build": {
    "beforeDevCommand": {
      "script": "node scripts/dev-web-or-reuse.mjs",
      "cwd": "../../..",
      "wait": false
    },
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm --workspace @margin/web run build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Margin",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 22,
          "y": 22
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "txt"],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "rank": "Default",
        "mimeType": "text/markdown",
        "contentTypes": ["net.daringfireball.markdown", "public.plain-text"]
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["margin"]
      }
    }
  }
}
