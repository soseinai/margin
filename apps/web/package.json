{
  "name": "@margin/web",
  "version": "0.1.8",
  "private": true,
  "type": "module",
  "scripts": {
    "build:markdown-core": "node ../../scripts/build-markdown-core-wasm.mjs",
    "prebenchmark:markdown": "npm run build:markdown-core",
    "benchmark:markdown": "vitest run --config vitest.benchmark.config.ts",
    "predev": "npm run build:markdown-core",
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:mobile": "vite --host 0.0.0.0 --port 5173",
    "prebuild": "npm run build:markdown-core",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "precheck": "npm run build:markdown-core",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "npm run test:unit && npm run test:integration",
    "pretest:unit": "npm run build:markdown-core",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "pretest:integration": "npm run build:markdown-core",
    "test:integration": "playwright test --config playwright.integration.config.ts",
    "test:e2e": "node -e \"console.log('No e2e tests configured yet')\""
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@lezer/highlight": "^1.2.3",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "svelte": "^5.43.7",
    "vite": "^7.2.4",
    "y-codemirror.next": "^0.3.5",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.11.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "fast-check": "^4.7.0",
    "svelte-check": "^4.3.4",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
