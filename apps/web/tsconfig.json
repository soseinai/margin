{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "checkJs": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"]
    },
    "types": ["svelte", "node"]
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
