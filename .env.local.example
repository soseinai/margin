# Copy this file to .env.local for local live E2E or release-preflight runs.
# .env.local is ignored by git and loaded automatically by just.
#
# Local Sosein Cloud dev server:
# MARGIN_SOSEIN_LIVE_URL=http://127.0.0.1:18787
#
# Public staging:
MARGIN_SOSEIN_LIVE_URL=https://api-staging.sosein.ai

# Secret shared with the target Sosein Cloud server's E2E session mint endpoint.
# Do not commit a real token.
MARGIN_SOSEIN_E2E_AUTH_TOKEN=
